# LATAM Book Generator — Environment Variables
# Copy this file to .env and fill in your API keys.
#
# ⚠️  IMPORTANT: The values below are NOT real keys.
#    They are placeholder examples showing the expected format.
#    Replace each one with your own actual API key.

# GitHub Models (free tier — for development)
# Get token at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_github_token_here

# DashScope / Qwen (text, images, TTS, voice cloning)
# Get key at: https://dashscope.aliyun.com/
DASHSCOPE_API_KEY=sk-your_dashscope_key_here

ANTHROPIC_API_KEY=sk-your_anthropic_key_here

# Optional: Enable OpenTelemetry tracing for AI Toolkit
# Set to 1 to export traces to VS Code AI Toolkit Agent Inspector
AITK_TRACING_ENABLED=0

# Optional: Enable detailed TTS diagnostic logging
TTS_DEBUG=1

# Optional: Force Qwen models for server.py
# USE_QWEN=false
# MODEL_ID=gpt-4o-mini
