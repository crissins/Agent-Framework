# Copy this file to .env and fill in your credentials
# For development: GitHub Models + DashScope (free tier available)
# For production: Qwen models recommended

# ==========================================
# TEXT GENERATION - Choose ONE provider
# ==========================================

# ===== OPTION 1: GitHub Models (Default for development) =====
# FREE TIER - Best for quick development without infrastructure setup
# Get token at: https://github.com/settings/tokens
# Create token with scope: read:packages
# Replace xxxx with your actual token
GITHUB_TOKEN="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"

# ===== OPTION 2: Qwen Models via DashScope (Production-ready) =====
# Get API key at: https://bailian.console.aliyun.com/
# Region selection is CRITICAL - do NOT mix regions!
# - Singapore: For international/non-China users
# - Beijing: For China mainland users  
# - US Virginia: For US-based deployments
# Replace xxxx with your actual DashScope API key
DASHSCOPE_API_KEY="sk-5708c8c83add457c98ba77ce58277748"

# ==========================================
# IMAGE GENERATION - DashScope (Required)
# ==========================================
# Same as DASHSCOPE_API_KEY above - used for Qwen-Image-Max
# This is required if you want to generate illustrations

# ==========================================
# OPTIONAL: Azure OpenAI (For production deployment)
# ==========================================
# Uncomment and fill in when ready to migrate to Azure infrastructure
# AZURE_OPENAI_ENDPOINT=https://your-instance.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT_NAME=deployment-name
# AZURE_OPENAI_API_KEY=your-azure-api-key

# ==========================================
# SETUP GUIDE
# ==========================================
# 1. GitHub Models:
#    - Go to: https://github.com/settings/tokens
#    - Click "Generate new token (classic)"
#    - Give it at least "read:packages" scope
#    - Copy the token to GITHUB_TOKEN above

# 2. DashScope (for Qwen models + image generation):
#    - Go to: https://bailian.console.aliyun.com/
#    - Create API key in your account
#    - Select region (Singapore recommended for international)
#    - Copy to DASHSCOPE_API_KEY above

# 3. Run the app:
#    - Streamlit: streamlit run app.py
#    - CLI demo: python main.py (or python main.py --qwen)
#    - Toggle model provider in Streamlit UI

